{
  "name": "taro-bluetooth-print",
  "version": "2.11.0",
  "description": "Taro \u84dd\u7259\u6253\u5370\u5e93 v2.6 - \u8f7b\u91cf\u7ea7\u3001\u9ad8\u6027\u80fd\u3001\u8de8\u5e73\u53f0\u652f\u6301\u5fae\u4fe1\u3001\u652f\u4ed8\u5b9d\u3001\u767e\u5ea6\u3001\u5b57\u8282\u8df3\u52a8\u5c0f\u7a0b\u5e8f\u53caH5 Web Bluetooth",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.umd.js"
    },
    "./core": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/core/index.es.js"
    },
    "./drivers": {
      "types": "./dist/types/drivers/index.d.ts",
      "import": "./dist/drivers/index.es.js"
    },
    "./adapters": {
      "types": "./dist/types/adapters/index.d.ts",
      "import": "./dist/adapters/index.es.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rimraf dist docs/.vitepress/dist",
    "build": "vite build",
    "dev": "vite build --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "taro",
    "bluetooth",
    "printer",
    "thermal",
    "escpos",
    "receipt",
    "label"
  ],
  "author": "Agions",
  "license": "MIT",
  "peerDependencies": {
    "@tarojs/taro": "^3.6.22"
  },
  "peerDependenciesMeta": {
    "@tarojs/taro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^4.5.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "sideEffects": false,
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "vite@<=6.4.1": ">=6.4.2",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
