{
  "name": "taro-bluetooth-print",
  "version": "1.0.6",
  "description": "跨平台蓝牙打印库，支持微信小程序、H5、React Native和鸿蒙等平台",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "eslint --ext .ts src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest"
  },
  "keywords": [
    "taro",
    "bluetooth",
    "printer",
    "esc/pos",
    "thermal-printer",
    "weapp",
    "h5",
    "react-native",
    "harmony"
  ],
  "author": "Agions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agions/taro-bluetooth-print.git"
  },
  "bugs": {
    "url": "https://github.com/agions/taro-bluetooth-print/issues"
  },
  "homepage": "https://github.com/agions/taro-bluetooth-print#readme",
  "peerDependencies": {
    "@tarojs/taro": ">=3.0.0"
  },
  "devDependencies": {
    "@tarojs/taro": "^3.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "@typescript-eslint/eslint-plugin": "^5.55.0",
    "@typescript-eslint/parser": "^5.55.0",
    "eslint": "^8.36.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.4",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
} 