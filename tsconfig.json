{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2017", "dom"],
    "jsx": "react",
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["src", "src/types/*.d.ts"],
  "exclude": ["node_modules", "dist", "example", "**/@types/**"]
} 